<tr class="user-row" id="<%= dom_id(user) %>">
  <td class="relative">
    <%= link_to user_user_profile_path(user), data: {remote: "true"} do %>
      <span class="absolute inset-0"></span>
      <%= user.user_profile.name %>
    <% end %>
  </td>
  <td class="relative">
    <%= link_to user_user_profile_path(user), data: {remote: "true"} do %>
      <span class="absolute inset-0"></span>
      <%= user.email %>
    <% end %>
  </td>
</tr>
