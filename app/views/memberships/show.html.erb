<% set_breadcrumbs [["Memberships", memberships_path],
                    [@membership.name, membership_path(@membership)]
                   ] %>

<% content_for :title, "Membership Details" %>

<div class="max-w-lg mx-auto">
  <div class="mb-16">
    <h1 class="text-4xl text-center">Membership Details</h1>
  </div>
  <div class="actions-row">
    <%= link_to "Back", new_membership_path, class: "btn-outline-primary btn--back" %>
    <%= link_to "Edit", edit_membership_path(@membership), class: "btn-outline-primary" %>
  </div>

  <div class="mt-4">
    <%= render @membership %>
  </div>

  <div class="mt-8 flex justify-start">
    <%= button_to "Delete", @membership, method: :delete,
                  data: { turbo_confirm: "Are you sure you want to delete this membership?" },
                  class: "btn-danger"
    %>
  </div>
</div>
