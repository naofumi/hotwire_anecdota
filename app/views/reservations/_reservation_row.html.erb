<tr class="" id="<%= dom_id reservation %>">
  <td class="p-2 border-gray-400 border-t">
    <%= reservation.guest_name %>
  </td>
  <td class="p-2 border-gray-400 border-t">
    <%= reservation.guest_phone %>
  </td>
  <td class="p-2 border-gray-400 border-t">
    <%= l reservation.check_in, format: :short %>
  </td>
  <td class="p-2 border-gray-400 border-t">
    <%= l reservation.check_out, format: :short %>
  </td>
  <td class="p-2 border-gray-400 border-t">
    <%= link_to '...', reservation_path(reservation), class: 'btn-outline-primary btn--sm' %>
  </td>
</tr>
